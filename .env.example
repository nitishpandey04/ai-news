# App
APP_ENV=development

# Database
DATABASE_URL=postgresql+asyncpg://newsuser:newspass@db:5432/newsdb

# Redis
REDIS_URL=redis://redis:6379/0

# WhatsApp (Meta Cloud API — leave blank to use mock)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=whatsapp_verify_secret

# Scheduler
DISPATCH_TICK_INTERVAL_SECONDS=300
